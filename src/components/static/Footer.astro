---
/**
 * Footer Component - Layer 0 (Static HTML)
 */
const year = new Date().getFullYear()
---

<footer class="border-t border-border bg-card/50 mt-auto">
  <div class="container-app py-8">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
      <!-- Brand -->
      <div class="md:col-span-2">
        <div class="flex items-center gap-2 mb-4">
          <span class="text-2xl">🐸</span>
          <span class="text-xl font-bold" style="font-family: var(--font-display);">
            <span class="text-primary">MEME</span><span class="text-accent">SCAN</span>
          </span>
        </div>
        <p class="text-sm text-muted-foreground max-w-md">
          Bloomberg for Memes. Real-time intelligence for the TON blockchain.
          Scan tokens, track rugs, find gems.
        </p>
        <div class="flex gap-3 mt-4">
          <a
            href="https://x.com/MemeSealTON"
            target="_blank"
            rel="noopener noreferrer"
            class="text-muted-foreground hover:text-primary transition-colors"
            aria-label="Twitter/X"
          >
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
            </svg>
          </a>
          <a
            href="https://t.me/MemeScanTON_bot"
            target="_blank"
            rel="noopener noreferrer"
            class="text-muted-foreground hover:text-primary transition-colors"
            aria-label="Telegram"
          >
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm4.64 6.8c-.15 1.58-.8 5.42-1.13 7.19-.14.75-.42 1-.68 1.03-.58.05-1.02-.38-1.58-.75-.88-.58-1.38-.94-2.23-1.5-.99-.65-.35-1.01.22-1.59.15-.15 2.71-2.48 2.76-2.69a.2.2 0 0 0-.05-.18c-.06-.05-.14-.03-.21-.02-.09.02-1.49.95-4.22 2.79-.4.27-.76.41-1.08.4-.36-.01-1.04-.2-1.55-.37-.63-.2-1.12-.31-1.08-.66.02-.18.27-.36.74-.55 2.92-1.27 4.86-2.11 5.83-2.51 2.78-1.16 3.35-1.36 3.73-1.36.08 0 .27.02.39.12.1.08.13.19.14.27-.01.06.01.24 0 .38z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="font-bold mb-4 text-sm uppercase tracking-wider">Scanner</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="/" class="text-muted-foreground hover:text-primary transition-colors">Trending</a></li>
          <li><a href="/crypto" class="text-muted-foreground hover:text-primary transition-colors">New Launches</a></li>
          <li><a href="/portfolio" class="text-muted-foreground hover:text-primary transition-colors">Watchlist</a></li>
        </ul>
      </div>

      <!-- More Links -->
      <div>
        <h3 class="font-bold mb-4 text-sm uppercase tracking-wider">Ecosystem</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="https://notaryton.com" target="_blank" class="text-muted-foreground hover:text-primary transition-colors">MemeSeal</a></li>
          <li><a href="/cryptokart" class="text-muted-foreground hover:text-primary transition-colors">CryptoKart</a></li>
          <li><a href="/rewards" class="text-muted-foreground hover:text-primary transition-colors">Rewards</a></li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="border-t border-border mt-8 pt-6 flex flex-col sm:flex-row justify-between items-center gap-4 text-xs text-muted-foreground">
      <p>&copy; {year} MemeScan. Built on TON.</p>
      <p class="flex items-center gap-1">
        <span class="status-live">LIVE</span>
        <span>Powered by TON Blockchain</span>
      </p>
    </div>
  </div>
</footer>
