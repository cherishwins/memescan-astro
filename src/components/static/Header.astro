---
/**
 * Header Component - Layer 0 (Static HTML)
 * Navigation works without JavaScript via regular <a> links
 */

interface Props {
  currentPath?: string
}

const { currentPath = '/' } = Astro.props

const navItems = [
  { href: '/', label: 'SCANNER', icon: '🔍' },
  { href: '/cryptokart', label: 'CRYPTOKART', icon: '🎮' },
  { href: '/rewards', label: 'REWARDS', icon: '🔥' },
  { href: '/crypto', label: 'TRENDING', icon: '📈' },
  { href: '/portfolio', label: 'WATCHLIST', icon: '📋' },
]
---

<header class="sticky top-0 z-50 border-b-2 border-primary bg-background/95 backdrop-blur">
  <div class="container-app py-2 sm:py-3">
    <div class="flex items-center justify-between">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 sm:gap-3 group">
        <div class="relative w-8 h-8 sm:w-10 sm:h-10 rounded-lg overflow-hidden border-2 border-primary neon-glow">
          <img
            src="/images/logo.png"
            alt="MemeScan"
            class="w-full h-full object-cover"
            loading="eager"
          />
        </div>
        <div>
          <h1 class="text-base sm:text-xl md:text-2xl font-black tracking-tight" style="font-family: var(--font-display);">
            <span class="text-primary text-glow">MEME</span><span class="text-accent">SCAN</span>
          </h1>
          <div class="text-[8px] sm:text-[10px] text-muted-foreground tracking-wider flex items-center gap-1">
            <svg class="w-2.5 h-2.5 sm:w-3 sm:h-3" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" />
            </svg>
            BLOOMBERG FOR MEMES
          </div>
        </div>
      </a>

      <!-- Desktop Navigation -->
      <nav class="hidden lg:flex items-center gap-1" aria-label="Main navigation">
        {navItems.map(item => (
          <a
            href={item.href}
            class:list={[
              'px-3 py-2 rounded-md text-sm font-bold transition-colors',
              currentPath === item.href
                ? 'bg-primary/20 text-primary'
                : 'text-muted-foreground hover:text-foreground hover:bg-secondary'
            ]}
          >
            <span class="mr-1">{item.icon}</span>
            {item.label}
          </a>
        ))}
      </nav>

      <!-- Right side: Status + Mobile Menu -->
      <div class="flex items-center gap-2">
        <!-- Live Status Badge -->
        <div class="hidden md:flex px-2 sm:px-3 py-1 bg-primary/20 border border-primary/50 rounded">
          <span class="status-live">TON LIVE</span>
        </div>

        <!-- Social Links (desktop) -->
        <div class="hidden sm:flex items-center gap-1">
          <a
            href="https://x.com/MemeSealTON"
            target="_blank"
            rel="noopener noreferrer"
            class="btn-ghost p-2 rounded-md"
            aria-label="Twitter/X"
          >
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
            </svg>
          </a>
          <a
            href="https://t.me/MemeScanTON_bot"
            target="_blank"
            rel="noopener noreferrer"
            class="btn-ghost p-2 rounded-md"
            aria-label="Telegram Bot"
          >
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm4.64 6.8c-.15 1.58-.8 5.42-1.13 7.19-.14.75-.42 1-.68 1.03-.58.05-1.02-.38-1.58-.75-.88-.58-1.38-.94-2.23-1.5-.99-.65-.35-1.01.22-1.59.15-.15 2.71-2.48 2.76-2.69a.2.2 0 0 0-.05-.18c-.06-.05-.14-.03-.21-.02-.09.02-1.49.95-4.22 2.79-.4.27-.76.41-1.08.4-.36-.01-1.04-.2-1.55-.37-.63-.2-1.12-.31-1.08-.66.02-.18.27-.36.74-.55 2.92-1.27 4.86-2.11 5.83-2.51 2.78-1.16 3.35-1.36 3.73-1.36.08 0 .27.02.39.12.1.08.13.19.14.27-.01.06.01.24 0 .38z"/>
            </svg>
          </a>
        </div>

        <!-- Mobile Menu (CSS-only dropdown) -->
        <details class="lg:hidden relative">
          <summary class="btn-ghost p-2 rounded-md cursor-pointer list-none" aria-label="Open menu">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
          </summary>
          <nav class="absolute right-0 top-full mt-2 w-48 bg-card border border-border rounded-lg shadow-lg py-2 z-50">
            {navItems.map(item => (
              <a
                href={item.href}
                class:list={[
                  'block px-4 py-2 text-sm transition-colors',
                  currentPath === item.href
                    ? 'bg-primary/20 text-primary'
                    : 'hover:bg-secondary'
                ]}
              >
                <span class="mr-2">{item.icon}</span>
                {item.label}
              </a>
            ))}
            <hr class="my-2 border-border" />
            <a
              href="https://x.com/MemeSealTON"
              target="_blank"
              rel="noopener noreferrer"
              class="block px-4 py-2 text-sm hover:bg-secondary"
            >
              Twitter/X
            </a>
            <a
              href="https://t.me/MemeScanTON_bot"
              target="_blank"
              rel="noopener noreferrer"
              class="block px-4 py-2 text-sm hover:bg-secondary"
            >
              Telegram Bot
            </a>
          </nav>
        </details>

        <!-- Connect Button -->
        <a href="/rewards" class="btn btn-primary text-xs h-8">
          CONNECT
        </a>
      </div>
    </div>
  </div>
</header>
